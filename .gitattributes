# Auto detect text files and ensure LF line endings
* text=auto eol=lf

# Markdown
*.md text diff=markdown

# Config files
*.yml text
*.yaml text
*.json text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
